# ================================
# 前端环境变量配置
# ================================
# 复制此文件为 .env.local 用于本地开发

# ================================
# API 配置
# ================================
# API 基础地址（生产环境通过运行时配置注入）
# 开发时使用相对路径，由 Vite 代理到后端
VITE_API_BASE=/api/v1

# 开发环境代理目标地址（仅开发时使用）
# 后端服务的地址
VITE_API_PROXY_TARGET=http://localhost:8080

# ================================
# GitHub 配置（可选）
# ================================
# GitHub Token 用于获取贡献日历数据
# 创建一个 fine-grained token 或 classic token，只需 public read 权限
# 生产环境通过运行时配置注入
VITE_GITHUB_TOKEN=
